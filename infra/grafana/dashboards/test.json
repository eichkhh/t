{
  "uid": "test-main",
  "title": "test — Observability",
  "tags": ["test"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "uid": "prometheus" },
        "query": "label_values(up, job)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Business",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Registrations / min",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(registrations_total[2m]) * 60",
          "legendFormat": "registrations"
        }
      ]
    },
    {
      "id": 3,
      "title": "Total Registrations",
      "type": "stat",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(registrations_total)", "legendFormat": "" }]
    },
    {
      "id": 4,
      "title": "Welcome Push (success vs failed)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 1, "w": 8, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "success" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        { "expr": "rate(welcome_push_total{status=\"success\"}[2m])", "legendFormat": "success" },
        { "expr": "rate(welcome_push_total{status=\"failed\"}[2m])", "legendFormat": "failed" }
      ]
    },
    {
      "id": 5,
      "title": "Push Success Rate",
      "type": "gauge",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "(sum(welcome_push_total{status=\"success\"}) or vector(0)) / ((sum(welcome_push_total{status=\"success\"}) or vector(0)) + (sum(welcome_push_total{status=\"failed\"}) or vector(0)))",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "HTTP Performance",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Request Rate (req/s) by service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 9, "w": 8, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_count{job=~\"$service\", net_host_port!~\"946.\"}[2m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 12,
      "title": "p50 / p95 / p99 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 9, "w": 8, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_duration_bucket{job=~\"$service\", net_host_port!~\"946.\"}[2m])) by (le, job))",
          "legendFormat": "p50 {{job}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_bucket{job=~\"$service\", net_host_port!~\"946.\"}[2m])) by (le, job))",
          "legendFormat": "p95 {{job}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_duration_bucket{job=~\"$service\", net_host_port!~\"946.\"}[2m])) by (le, job))",
          "legendFormat": "p99 {{job}}"
        }
      ]
    },
    {
      "id": 13,
      "title": "HTTP Error Rate (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 9, "w": 8, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "5xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "4xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "refId": "5xx",
          "expr": "sum(rate(http_server_duration_count{job=~\"$service\", http_status_code=~\"5..\"}[2m])) by (job)",
          "legendFormat": "5xx {{job}}"
        },
        {
          "refId": "4xx",
          "expr": "sum(rate(http_server_duration_count{job=~\"$service\", http_status_code=~\"4..\"}[2m])) by (job)",
          "legendFormat": "4xx {{job}}"
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "BullMQ — Welcome Queue",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 41,
      "title": "Queue Job States (current snapshot)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "failed" },    "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "waiting" },   "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "active" },    "properties": [{ "id": "color", "value": { "fixedColor": "blue",   "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "delayed" },   "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "completed" }, "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] }
        ]
      },
      "targets": [
        { "expr": "bullmq_jobs{state=\"waiting\"}",   "legendFormat": "waiting" },
        { "expr": "bullmq_jobs{state=\"active\"}",    "legendFormat": "active" },
        { "expr": "bullmq_jobs{state=\"delayed\"}",   "legendFormat": "delayed" },
        { "expr": "bullmq_jobs{state=\"failed\"}",    "legendFormat": "failed" },
        { "expr": "bullmq_jobs{state=\"completed\"}", "legendFormat": "completed" }
      ]
    },
    {
      "id": 42,
      "title": "Failed Jobs",
      "type": "stat",
      "gridPos": { "x": 12, "y": 17, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "bullmq_jobs{state=\"failed\"}", "legendFormat": "" }]
    },
    {
      "id": 43,
      "title": "Waiting Jobs",
      "type": "stat",
      "gridPos": { "x": 16, "y": 17, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "bullmq_jobs{state=\"waiting\"}", "legendFormat": "" }]
    },
    {
      "id": 44,
      "title": "Delayed (Scheduled) Jobs",
      "type": "stat",
      "gridPos": { "x": 20, "y": 17, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "bullmq_jobs{state=\"delayed\"}", "legendFormat": "" }]
    },
    {
      "id": 45,
      "title": "Active Workers",
      "type": "stat",
      "gridPos": { "x": 12, "y": 21, "w": 4, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "bullmq_jobs{state=\"active\"}", "legendFormat": "" }]
    },
    {
      "id": 46,
      "title": "Job Failure Rate (per min)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 21, "w": 8, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "targets": [
        {
          "expr": "rate(welcome_push_total{status=\"failed\"}[2m]) * 60",
          "legendFormat": "failures/min"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Outbox Health",
      "gridPos": { "x": 0, "y": 25, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 31,
      "title": "Outbox Relay Rate (success vs failed)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "success" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        { "expr": "rate(outbox_relay_total{status=\"success\"}[2m])", "legendFormat": "success" },
        { "expr": "rate(outbox_relay_total{status=\"failed\"}[2m])", "legendFormat": "failed" }
      ]
    },
    {
      "id": 32,
      "title": "Stuck Rows Recovered (last 1h)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 26, "w": 6, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "(sum(increase(outbox_recovered_total[1h])) or vector(0))", "legendFormat": "" }]
    },
    {
      "id": 33,
      "title": "Outbox Relay Success Rate",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 26, "w": 6, "h": 7 },
      "datasource": { "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "(sum(outbox_relay_total{status=\"success\"}) or vector(0)) / ((sum(outbox_relay_total{status=\"success\"}) or vector(0)) + (sum(outbox_relay_total{status=\"failed\"}) or vector(0)))",
          "legendFormat": ""
        }
      ]
    }
  ]
}
